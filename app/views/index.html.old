{% extends "layouts/main.html" %}

{% block pageTitle %}
Manage your EU VAT claim – GOV.UK
{% endblock %}

{% block content %}

javascript:history.back() class="govuk-back-link">Back</a>

<h1 class="govuk-heading-l">
  Manage your EU VAT claim
</h1>

<p class="govuk-body">
  Use this service to claim back EU VAT on a purchase or import from a EU member state.
</p>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-one-half">

    <div class="govuk-summary-card">
      <div class="govuk-summary-card__content">

        <h2 class="govuk-heading-m">
          /create-an-eu-vat-claim
            Make a new EU VAT claim
          </a>
        </h2>

        <p class="govuk-body">
          Start a claim to get back VAT paid in an EU member state on purchases or imports.
        </p>

      </div>
    </div>

  </div>

  <div class="govuk-grid-column-one-half">

    <div class="govuk-summary-card">
      <div class="govuk-summary-card__content">

        <h2 class="govuk-heading-m">
          #
            View or manage claims
          </a>
        </h2>

        <p class="govuk-body">
          You have submitted 2 claims and have 1 claim in progress.
        </p>

      </div>
    </div>

  </div>
</div>

{% endblock %}